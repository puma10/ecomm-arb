# Application
DEBUG=true
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ecom_arb

# Stripe (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# URLs — portless routes .localhost hostnames to ephemeral ports
FRONTEND_URL=https://ecomm.localhost:1355
STRIPE_SUCCESS_URL=https://ecomm.localhost:1355/order/{order_id}
STRIPE_CANCEL_URL=https://ecomm.localhost:1355/checkout/{product_slug}

# Google Ads API (get from Google Cloud Console + Google Ads)
GOOGLE_ADS_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=your-client-secret
GOOGLE_ADS_REFRESH_TOKEN=your-refresh-token
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
GOOGLE_ADS_CUSTOMER_ID=123-456-7890

# ScraperAPI for Amazon scraping (handles blocks, CAPTCHAs, US geo-targeting)
# Sign up at https://www.scraperapi.com/ (1,000 free requests/month)
SCRAPERAPI_KEY=

# OpenRouter for LLM analysis (product understanding, keyword scoring)
# Sign up at https://openrouter.ai/
OPENROUTER_API_KEY=
