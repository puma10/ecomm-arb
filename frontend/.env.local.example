# API URL (browser-side) — portless routes https://api.ecomm.localhost to the API
NEXT_PUBLIC_API_URL=https://api.ecomm.localhost:1355/api

# API URL (server-side, SSR) — direct localhost bypasses .localhost DNS issues in Node.js
# Auto-set by Makefile from the API's ephemeral port. Override if needed:
# INTERNAL_API_URL=http://127.0.0.1:PORT/api
